# ============================================================
#  Rebocap Doc — Deployment Environment Variables
#
#  Copy to /opt/rebocap-doc/.env and fill in your values:
#    cp scripts/.env.example .env
#    chmod 600 .env
# ============================================================

# ── Proxy (Xray local client) ───────────────────────────────
# HTTP proxy port exposed by the local Xray client.
# Xray listens on 127.0.0.1:10809 and tunnels GitHub traffic
# through VLESS to bypass GFW restrictions.
# Change only if you modified xray-config.json.
PROXY_PORT=10809

# ── GitHub Webhook ──────────────────────────────────────────
# Secret for verifying GitHub webhook payloads.
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=change-me-to-a-random-string

# Port for the webhook HTTP server (default 9000)
WEBHOOK_PORT=8089

# ── Alibaba Cloud DCDN ──────────────────────────────────────
# RAM user with DCDN refresh permission (AliyunDCDNFullAccess or custom policy).
# Create at: https://ram.console.aliyun.com/users
ALI_ACCESS_KEY_ID=your-access-key-id
ALI_ACCESS_KEY_SECRET=your-access-key-secret

# Domain name configured in Alibaba DCDN
DCDN_DOMAIN=doc.rebocap.com

# ── Deploy mode ────────────────────────────────────────────
# "dev"  — skip CDN refresh (for migration / testing phase)
# "prod" — full deploy including DCDN refresh (default)
DEPLOY_MODE=dev

# ── Optional ────────────────────────────────────────────────
# Project directory (default: /opt/rebocap-doc)
# PROJECT_DIR=/opt/rebocap-doc
